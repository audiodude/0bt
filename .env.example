# 0bt environment configuration. Copy to .env and edit.

# --- Public-facing identity ----------------------------------------------------
# Full base URL where the service is reachable. Required for correct magnet
# and torrent URLs. Must match what's in front of the app (Caddy domain in
# production, http://localhost:8080 for plain local dev).
FHOST_BASE_URL=http://localhost:8080

# --- Storage / DB --------------------------------------------------------------
# In-container paths under /data; the compose file maps them to a named volume.
FHOST_STORAGE_PATH=/data/up
FHOST_DB_URL=sqlite:////data/db/0bt.sqlite

# --- Limits --------------------------------------------------------------------
# Max upload size in bytes. Default 1.5 GiB.
FHOST_MAX_CONTENT_LENGTH=1610612736

# --- Retention curve (days) ----------------------------------------------------
# Smaller files live longer; files at max_size live for min_days.
FHOST_RETENTION_MIN_DAYS=30
FHOST_RETENTION_MAX_DAYS=365

# --- BitTorrent ----------------------------------------------------------------
# Public trackers baked into every magnet/.torrent.
FHOST_TRACKERS=udp://tracker.opentrackr.org:1337/announce,udp://tracker.openbittorrent.com:6969/announce,udp://open.tracker.cl:1337/announce,udp://exodus.desync.com:6969/announce

# Optional self-hosted external tracker (e.g., udp://tracker.example:6969/announce).
# The app already serves its own /announce; this is only needed if you want to
# also run an opentracker/XBT instance for a private swarm.
FHOST_INTERNAL_TRACKER=

# Host port that maps to transmission's BT peer port inside the container.
# Open 51413/tcp + 51413/udp on your firewall for inbound BT peering.
BT_PEER_PORT=51413

# --- Transmission RPC ----------------------------------------------------------
TRANSMISSION_RPC_HOST=transmission
TRANSMISSION_RPC_PORT=9091
TRANSMISSION_RPC_USER=transmission
# REQUIRED: set a strong password before deploying.
TRANSMISSION_RPC_PASSWORD=change-me-or-die
TRANSMISSION_RPC_PATH=/transmission/rpc

# --- Reverse proxy hint --------------------------------------------------------
# When behind nginx/Caddy with X-Accel-Redirect support, set to 1 to offload
# large file downloads from the Python process. 0 = Flask serves bytes itself.
FHOST_USE_X_ACCEL_REDIRECT=0

# --- MIME blacklist (comma-separated) ------------------------------------------
FHOST_MIME_BLACKLIST=application/x-dosexec,application/java-archive,application/java-vm

# --- Caddy reverse proxy (compose profile=caddy) -------------------------------
# Domain name to terminate TLS for. Required when using the caddy profile.
CADDY_DOMAIN=
# Email used for Let's Encrypt registration / cert expiry warnings.
CADDY_ADMIN_EMAIL=admin@example.com

# --- App port ------------------------------------------------------------------
# Host port for the plain HTTP app listener (only used when you're NOT running
# Caddy in front; Caddy uses 80/443 directly).
APP_PORT=8080

# --- Worker --------------------------------------------------------------------
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=600
