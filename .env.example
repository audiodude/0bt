# 0bt environment configuration. Copy to .env and edit.

# --- Public-facing identity ----------------------------------------------------
# The full base URL the service is reachable at. Required for correct magnet/HTTP
# links. Use http://localhost:8080 for plain local dev.
FHOST_BASE_URL=http://localhost:8080

# --- Storage / DB --------------------------------------------------------------
# These default to in-container paths under /data. The compose file maps them to
# named volumes; you usually don't need to change them.
FHOST_STORAGE_PATH=/data/up
FHOST_DB_URL=sqlite:////data/db/0bt.sqlite

# --- Limits --------------------------------------------------------------------
# Max upload size in bytes. Default 1.5 GiB.
FHOST_MAX_CONTENT_LENGTH=1610612736

# --- Retention curve (days) ----------------------------------------------------
FHOST_RETENTION_MIN_DAYS=30
FHOST_RETENTION_MAX_DAYS=365

# --- BitTorrent ----------------------------------------------------------------
# Public trackers baked into every magnet/.torrent.
FHOST_TRACKERS=udp://tracker.opentrackr.org:1337/announce,udp://tracker.openbittorrent.com:6969/announce,udp://open.tracker.cl:1337/announce,udp://exodus.desync.com:6969/announce

# Optional self-hosted tracker URL (e.g., udp://your.host:6969/announce). Empty = none.
FHOST_INTERNAL_TRACKER=

# --- Transmission RPC ----------------------------------------------------------
TRANSMISSION_RPC_HOST=transmission
TRANSMISSION_RPC_PORT=9091
TRANSMISSION_RPC_USER=transmission
# REQUIRED: set a strong password before deploying.
TRANSMISSION_RPC_PASSWORD=change-me-or-die
TRANSMISSION_RPC_PATH=/transmission/rpc

# --- Reverse proxy hint --------------------------------------------------------
# When behind a proxy that supports it (caddy/nginx), use X-Accel-Redirect to
# offload large file downloads from the Python process. Set to 1 for nginx-style
# (X-Accel-Redirect), 2 for Caddy-style (X-Sendfile / X-Accel-Redirect with
# rewrite), 0 to disable (Flask serves bytes itself).
FHOST_USE_X_ACCEL_REDIRECT=0

# --- Mime blacklist (comma-separated) ------------------------------------------
FHOST_MIME_BLACKLIST=application/x-dosexec,application/java-archive,application/java-vm

# --- Caddy reverse proxy (compose profile=caddy) -------------------------------
# Domain name to terminate TLS for. Set to e.g. files.example.com to enable
# automatic Let's Encrypt cert via Caddy.
CADDY_DOMAIN=

# --- Worker ---------------------------------------------------------------------
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=600
